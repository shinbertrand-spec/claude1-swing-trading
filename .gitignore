# Local-only Claude Code config (per-machine permissions, hooks, etc.)
.claude/settings.local.json

# Broker credentials — Tiger Open Platform private key + account IDs.
# Canonical location is C:\Users\User\Desktop\tiger\ (outside this repo);
# these patterns are defense-in-depth in case any cred file lands inside
# the project tree by accident.
.env
.env.*
!.env.example
*.pem
*.key
**/tiger/
**/.tiger/
**/broker_credentials/

# Trading history, journal entries, positions, candidate snapshots — local state
journal/

# Personal position + candidate ledgers (real share counts, cost basis, stops).
# The schema (_schema/) and worked examples (_examples/) ARE tracked so the
# framework is reproducible; the live per-ticker ledgers are not — same convention
# as journal/.
ledgers/positions/
ledgers/candidates/
# Per-decision debate ledgers (<TICKER>-<DATE>.yml) are ephemeral gate output
# and reference the ignored candidate ledgers; _schema/ + _examples/ stay tracked.
ledgers/debate/*.yml

# Paper-auto track ledgers (autonomous paper-trading; validation only, no
# live capital). Track separation per CLAUDE.md § Broker bridge → § Paper-auto.
ledgers/paper-auto/

# Auto-paper run-state directories — runtime artifacts, regenerable.
# Each /auto-paper invocation creates one dir under here per
# [auto-paper LLM/Python boundary refactor 2026-05-28] §3.7.
ledgers/_auto_paper_runs/

# Self-observability cockpit alert-state (edge-trigger de-dup; runtime, regenerable).
# The HTML panel + snapshot json live under journal/ (already ignored above).
ledgers/observability/

# Insider-KIND derived event files (built offline from SEC Form 4 ingest +
# classifier + conviction; large, regenerable from tools.fundamentals.insider_events).
ledgers/insider/

# Scratch directory for one-off scripts. Operational state only.
tmp/

# Thematic-portfolio runtime state — kill-switch peak / events / heartbeat /
# kill-event flag. Per [[swing-thematic-portfolio-kill-switch-architecture]]
# Process B writes these every cycle; not source-of-truth, regenerable.
ledgers/thematic/kill_switch/_state/

# Thematic-portfolio Loop 1 firing log (artifact classifier rate-limit state).
ledgers/thematic/loop1/_state/

# News-research runtime state — rolling StockTwits baseline (per-ticker
# volume_z warmup). Self-heals in <24h; matches kill_switch/loop1 _state
# precedent. Was tracked by oversight before 2026-05-28.
ledgers/news/_state/social_baseline.json

# News-research market-temperature cache — TTL'd JSON per fetcher
# (put_call / fear_greed / aaii / vix_term). Regenerable on next call.
# Schema 1.3 (2026-05-29).
ledgers/news/_state/market_temperature_cache/

# Thematic-portfolio raw 13F fetches — regenerable from EDGAR via
# tools.thematic_portfolio.corpus.thirteen_f --ensemble. Loop 1 outputs
# (the LLM audit trail) ARE tracked; the raw 13F snapshots are not.
ledgers/thematic/13f/

# Thematic-portfolio Tier 3 signal snapshots — regenerable from yfinance /
# EDGAR via tools.thematic_portfolio.tier3.*. Prices move daily; the
# canonical record is the Loop 1 output JSON that cites these by ticker.
ledgers/thematic/tier3/

# Thematic-portfolio X-timeline corpus — regenerable from twitterapi.io
# via tools.thematic_portfolio.corpus.x_ingest. Per-post YAMLs +
# last-seen state file (analogous to the 13F + tier3 conventions —
# raw auto-fetches not tracked; canonical record is the Loop 1
# output JSON that cites them).
ledgers/thematic/corpus/x/

# Thematic-portfolio dry-run bundle scratch + per-position critic input
# bundles + per-firing input bundle. All regenerable: _dryrun/ from
# build_live_bundle, __critic_inputs/ from the Loop 1 output JSON,
# __bundle.json from build_live_bundle.
ledgers/thematic/loop1/_dryrun/
ledgers/thematic/loop1/*__critic_inputs/
ledgers/thematic/loop1/*__bundle.json

# News snapshots — runtime data, regenerable from the bot. Schema + examples tracked.
ledgers/news/[0-9]*-[0-9]*-[0-9]*/

# Swing-critic panel per-day outputs — regenerable; schema tracked.
ledgers/swing-critics/[0-9]*-[0-9]*-[0-9]*/
ledgers/swing-critics/_calibration/

# Old portfolio snapshot reference (pre-cash-out)
price_check_may14.jsx

# Local plans / scratch
plans/

# Python (Phase 2 tools layer)
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
uv.lock

# Phase 5 backtest OHLCV cache (fetched data; reproducible from yfinance)
tools/backtest/cache/

# Phase 6 tool caches (EDGAR EPS lookups, etc — re-fetchable, 24h TTL)
tools/cache/

# Phase 5 backtest result reports (regenerable; large markdown files)
backtest_results/

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
~$*
*.tmp

# Underscore-prefixed scratch / one-off scripts (not part of the operational set)
scripts/_*
